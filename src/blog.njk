---
layout: base.njk
title: Blog | Fahd Ashour
description: Explore my blogs about web development, design, and technology.
---

<main class="blog-page">
  <header class="blog-header">
    <h1>Blog</h1>
    <p>My own thoughts, ideas, and insights, takes on web development, design, and Software</p>
  </header>

  <section aria-labelledby="blogs-heading">
    <h2 id="blogs-heading" class="sr-only">Blog Posts</h2>

    {% if collections.allBlogPosts.length > 0 %}
    <div class="blog-list" role="list" aria-label="Blog posts">
      {% for post in collections.allBlogPosts %}
      <a
        href="{{ post.url }}"
        class="bookmark-item"
        role="listitem"
        {% if post.data.external %}target="_blank" rel="noopener noreferrer"{% endif %}
      >
        <span class="bookmark-title bookmark-title-line">
          {{ post.data.title }}
          {% if post.data.external %}{% include "icons/external-link.njk" %}{% endif %}
        </span>
        {% if post.data.date and post.data.source %}
        <span class="bookmark-url">{{ post.data.date | dateFormat }} - {{ post.data.source }} - {{ post.url }}</span>
        {% elif post.data.date %}
        <span class="bookmark-url">{{ post.data.date | dateFormat }} - {{ post.url }}</span>
        {% else %}
        <span class="bookmark-url">{{ post.url }}</span>
        {% endif %}
      </a>
      {% endfor %}
    </div>
    {% else %}
    <div class="empty-state">
      <h1>no blogs yet, sorry :(</h1>
    </div>
    {% endif %}
  </section>
</main>
