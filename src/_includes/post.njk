---
layout: base.njk
giscus: true
---

<main class="blog-post">
  <article>
    <header class="post-header">
      <time datetime="{{ date | dateFormat }}" class="post-date">{{ date | dateFormat }}</time>
      {% if tags %}
      <div class="post-tags">
        {% for tag in tags %}
        <span class="tag">{{ tag }}</span>
        {% endfor %}
      </div>
      {% endif %}
    </header>
    
    <h1 class="post-title">{{ title }}</h1>
    
    {% if coverImage %}
    <img src="{{ coverImage }}" alt="Cover image for {{ title }}" class="post-cover">
    {% endif %}
    
    <div class="post-content">
      {{ content | safe }}
    </div>
  </article>
  
  {% if giscus %}
  <section class="comments-section" aria-labelledby="comments-title">
    <div class="comments-card">
      <div class="comments-header">
        <h2 id="comments-title">Discussion</h2>
        <p>Comment with your GitHub account.</p>
      </div>
      <div class="giscus-shell">
        <script src="https://giscus.app/client.js"
                data-repo="fahdfady/fahddev"
                data-repo-id="R_kgDOGRjDvA"
                data-category="General"
                data-category-id="DIC_kwDOGRjDvM4C0wjz"
                data-mapping="pathname"
                data-strict="0"
                data-reactions-enabled="1"
                data-emit-metadata="1"
                data-input-position="top"
                data-theme="light"
                data-lang="en"
                data-loading="lazy"
                crossorigin="anonymous"
                async>
        </script>
      </div>
    </div>
  </section>
  {% endif %}
</main>
