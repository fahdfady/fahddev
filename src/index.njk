  <!-- About Section -->
  <section aria-label="about" class="about">
    <p>Currently learning Computer Science. Interested in Web Development, <a href="https://react.dev">React JS</a>, and <a href="https://rust-lang.org">Rust</a>.</p>
    <p>Ex-founding SWE <a href="https://x.com/OblienHQ" class="bold-black" target="_blank">Oblien</a>, a tech startup that has upcoming product yet to be announced.</p>
    <p>Building <a href="https://x.com/BLEU_io" class="bold-blue" target="_blank">BLEU Community</a>, a Discord-based community for people interested in computer science.</p>
    <p>What am I looking forward to do in my career? Learning how Front-end Frameworks works. <a href="https://github.com/fahdfady/yaseer" target="_blank">Building my own Framework</a>, Contributing to open-source projects that I'm genuinely interested in. Passing my knowledge to others via my <a href="https://x.com/fahdashwr" target="_blank">Twitter account</a> and <a href="/blog/">Blog</a>.</p>
    <p><a href="https://drive.google.com/file/d/1kZV7Ing6HF-Ooxt9pXTtllcGGcG1re1-/view?usp=sharing" target="_blank">link to my resume</a></p>
  </section>

  <!-- Currently Working On Section -->
  <section aria-label="currently working on" id="working-on" class="working-on">
    <h2 class="section-header"><a href="#working-on">Currently Working On</a></h2>
    <div class="working-list">
      <p>Building <a href="https://github.com/fahdfady/metassr" target="_blank">MetaSSR</a> — exploring server-side rendering patterns</p>
      <p>🦀 Actively maintaining the <a href="https://github.com/metacall/core" target="_blank">MetaCall Rust port</a></p>
      <p>My most interesting project right now: <a href="https://github.com/fahdfady/polyglot-api-handler" target="_blank">polyglot-api-handler</a></p>
      <p>Preparing to create a devlog documenting this journey... but I'm just too busy right now (maybe lazy, most certainly overwhelmed)</p>
    </div>
    <p class="contributions-link">
      <a href="https://gist.github.com/fahdfady/40116fcf0d80567a7ec343e1d06acec1" target="_blank">
        View my open source contributions →
      </a>
    </p>

  </section>

  <!-- I am reading Section -->
  <section aria-label="reading" id="reading" class="reading-section">
    <h2 class="section-header"><a href="#reading">I am reading</a></h2>
    <div class="reading-grid">
      {% for book in reading %}
      <a href="{{ book.link }}" class="book-card" target="_blank">
        <div class="book-cover">
          <img src="{{ book.image }}" alt="{{ book.title }} cover">
        </div>
        <div class="book-info">
          <h3 class="book-title">{{ book.title }}</h3>
          <p class="book-author">by {{ book.author }}</p>
        </div>
      </a>
      {% endfor %}
    </div>
  </section>

  <!-- Spiderman GIF -->
  <section class="gif-section">
    <iframe src="https://giphy.com/embed/1xnOVciG4m6DDrS90I" width="480" height="343" frameBorder="0" allowFullScreen></iframe>
    <p><a href="https://giphy.com/stickers/leroypatterson-animated-1xnOVciG4m6DDrS90I">via GIPHY</a></p>
  </section>

  <!-- Projects Section -->
  <section aria-label="projects" id="projects">
    <h2 class="section-header"><a href="#projects">Projects</a></h2>
    
    <div class="projects-grid">
      {% for project in projects %}
      <a href="{{ project.link }}" class="project-card" target="_blank">
        <h5 class="project-year">{{ project.year }}</h5>
        <h3 class="project-name">{{ project.name }}</h3>
        <p class="project-description">{{ project.description }}</p>
        <span class="project-link">{{ project.link }}</span>
      </a>
      {% endfor %}
    </div>
  </section>

  <!-- Toolkit Section -->
  <section aria-label="toolkit" id="toolkit">
    <h2 class="section-header"><a href="#toolkit">Toolkit</a></h2>
    
    <p class="toolkit-intro">I'm comfortable using:</p>
    
    <div class="toolkit-grid">
      {% for skill in skills %}
      <a href="{{ skill.link }}" target="_blank" rel="noopener noreferrer" class="skill-card">
        <div class="skill-icon">
          {% include "icons/" + skill.name + ".njk" %}
        </div>
        <div class="skill-name">{{ skill.name }}</div>
        <span class="skill-category">{{ skill.category }}</span>
      </a>
      {% endfor %}
    </div>
  </section>
</main>
